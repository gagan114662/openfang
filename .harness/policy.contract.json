{
  "version": "1",
  "rolloutPolicy": {
    "currentPhase": "phase-2",
    "runFanoutOnGateFailure": false,
    "phases": {
      "phase-0": {
        "description": "Advisory baseline",
        "enforceMergeBlock": false,
        "enforceReviewState": false,
        "enforceDocsDrift": false,
        "enableRemediation": false,
        "requireEvidence": false
      },
      "phase-1": {
        "description": "Current-head review enforcement",
        "enforceMergeBlock": true,
        "enforceReviewState": true,
        "enforceDocsDrift": true,
        "enableRemediation": false,
        "requireEvidence": false
      },
      "phase-2": {
        "description": "Strict Claude+Codex pre-approval loop",
        "enforceMergeBlock": true,
        "enforceReviewState": true,
        "enforceDocsDrift": true,
        "enableRemediation": true,
        "requireEvidence": true
      }
    }
  },
  "riskTierRules": {
    "critical": [
      "crates/openfang-runtime/**",
      "crates/openfang-kernel/**",
      "crates/openfang-memory/**",
      "crates/openfang-types/src/agent.rs",
      "crates/openfang-types/src/capability.rs"
    ],
    "high": [
      "crates/openfang-api/**",
      "crates/openfang-channels/**",
      "crates/openfang-cli/**",
      "crates/openfang-telegram/**"
    ],
    "medium": [
      "crates/openfang-extensions/**",
      "crates/openfang-skills/**",
      "crates/openfang-hands/**",
      "agents/**"
    ],
    "low": [
      "**"
    ]
  },
  "mergePolicy": {
    "critical": {
      "requiredChecks": [
        "risk-policy-gate",
        "claude-remediation-agent",
        "pr-review-harness",
        "ci-check",
        "ci-test",
        "ci-clippy",
        "ci-fmt",
        "ci-audit",
        "ci-secrets",
        "sentry-live-validate"
      ]
    },
    "high": {
      "requiredChecks": [
        "risk-policy-gate",
        "claude-remediation-agent",
        "pr-review-harness",
        "ci-check",
        "ci-test",
        "ci-clippy",
        "ci-fmt",
        "sentry-live-validate"
      ]
    },
    "medium": {
      "requiredChecks": [
        "risk-policy-gate",
        "claude-remediation-agent",
        "pr-review-harness",
        "ci-check",
        "ci-test",
        "ci-clippy"
      ]
    },
    "low": {
      "requiredChecks": [
        "risk-policy-gate",
        "claude-remediation-agent",
        "pr-review-harness",
        "ci-check"
      ]
    }
  },
  "reviewPolicy": {
    "provider": "greptile",
    "checkRunName": "greptile-review",
    "timeoutMinutes": 20,
    "weakConfidenceThreshold": 0.55,
    "actionableSummaryKeywords": [
      "vulnerability",
      "security",
      "exploit",
      "auth bypass",
      "injection",
      "rce",
      "critical"
    ]
  },
  "reviewProviders": {
    "providers": {
      "greptile": {
        "enforcement": "advisory",
        "requireCurrentHeadIngestion": true,
        "checkRunName": "greptile-review"
      },
      "claude": {
        "enforcement": "required",
        "requireCurrentHeadIngestion": true,
        "marker": "<!-- claude-review-findings -->",
        "weakConfidenceThreshold": 0.55,
        "actionableSummaryKeywords": [
          "vulnerability",
          "security",
          "critical",
          "data leak",
          "broken auth"
        ],
        "github": {
          "trustedAppIdsEnv": "OPENFANG_CLAUDE_TRUSTED_APP_IDS",
          "trustedLogins": [
            "claude[bot]"
          ],
          "maintainerAllowlist": []
        }
      }
    }
  },
  "automation": {
    "claudeRemediation": {
      "enabled": true,
      "runOnEverySync": true,
      "requireFindingsIngestion": false,
      "maxAttemptsPerSha": 1
    }
  },
  "docsDriftRules": [
    {
      "name": "api-docs-drift",
      "whenTouched": [
        "crates/openfang-api/src/**",
        "crates/openfang-types/src/config.rs"
      ],
      "requireAny": [
        "docs/api-reference.md",
        "docs/configuration.md",
        "README.md"
      ]
    }
  ],
  "evidencePolicy": {
    "uiImpactPaths": [
      "crates/openfang-api/static/**",
      "crates/openfang-desktop/**",
      "frontend/**"
    ],
    "requiredFlows": [
      "app-launch",
      "changed-feature-path"
    ],
    "requiredAssertions": [
      "entrypoint.embedded_browser",
      "identity.expected_account"
    ]
  },
  "remediationPolicy": {
    "maxAttemptsPerSha": 1,
    "allowedPathGlobs": [
      "crates/**/src/**/*.rs",
      "tests/**/*.rs",
      "docs/**/*.md",
      "scripts/**/*.py"
    ],
    "forbiddenPathGlobs": [
      ".git/**",
      ".github/**",
      "target/**",
      "Cargo.lock",
      ".harness/**"
    ],
    "validationCommands": [
      "cargo check --workspace"
    ]
  },
  "rerunPolicy": {
    "marker": "<!-- review-agent-auto-rerun -->"
  },
  "sentryPolicy": {
    "query": "is:unresolved level:error",
    "tokenEnv": "SENTRY_AUTH_TOKEN"
  }
}
