{
  "version": "1.0.0",
  "description": "OpenFang Harness Policy Contract - defines risk tiers, required checks, and rollout phases",
  "rolloutPolicy": {
    "currentPhase": "phase-0",
    "runFanoutOnGateFailure": true,
    "phases": {
      "phase-0": {
        "description": "Advisory baseline and metrics collection",
        "enforceMergeBlock": true,
        "enableRemediation": false,
        "enforceReviewState": true,
        "requireEvidence": true
      },
      "phase-1": {
        "description": "Block stale review/docs drift, pilot remediation on labeled PRs",
        "enforceMergeBlock": true,
        "enableRemediation": "labeled-only",
        "remediationLabel": "harness-remediation-pilot"
      },
      "phase-2": {
        "description": "Enforce constrained remediation + evidence requirements",
        "enforceMergeBlock": true,
        "enableRemediation": true,
        "requireEvidence": true
      },
      "phase-3": {
        "description": "Full hard enforcement",
        "enforceMergeBlock": true,
        "enableRemediation": true,
        "requireEvidence": true,
        "strictReview": true
      }
    }
  },
  "riskTiers": {
    "critical": {
      "description": "Changes to core runtime, kernel, or memory systems",
      "paths": [
        "crates/openfang-runtime/**",
        "crates/openfang-kernel/**",
        "crates/openfang-memory/**",
        "crates/openfang-types/src/agent.rs",
        "crates/openfang-types/src/capability.rs"
      ],
      "requiredChecks": [
        "build",
        "test",
        "clippy",
        "security-audit",
        "integration-tests",
        "code-review",
        "agent-evals-pr",
        "agent-evals-live-pr",
        "infra-preflight",
        "sentry-live-validate"
      ],
      "reviewPolicy": {
        "minApprovals": 2,
        "requireOwnerReview": true
      }
    },
    "high": {
      "description": "Changes to API, channels, or CLI",
      "paths": [
        "crates/openfang-api/**",
        "crates/openfang-channels/**",
        "crates/openfang-cli/**",
        "crates/openfang-telegram/**"
      ],
      "requiredChecks": [
        "build",
        "test",
        "clippy",
        "integration-tests",
        "agent-evals-pr",
        "agent-evals-live-pr",
        "infra-preflight",
        "sentry-live-validate"
      ],
      "reviewPolicy": {
        "minApprovals": 1
      }
    },
    "medium": {
      "description": "Changes to extensions, skills, or hands",
      "paths": [
        "crates/openfang-extensions/**",
        "crates/openfang-skills/**",
        "crates/openfang-hands/**",
        "agents/**"
      ],
      "requiredChecks": [
        "build",
        "test",
        "clippy",
        "agent-evals-pr",
        "infra-preflight"
      ],
      "reviewPolicy": {
        "minApprovals": 1
      }
    },
    "low": {
      "description": "Documentation, configs, or scripts",
      "paths": [
        "docs/**",
        "*.md",
        "scripts/**",
        "*.toml.example",
        ".github/**"
      ],
      "requiredChecks": [
        "risk-policy-gate",
        "docs-lint",
        "infra-preflight"
      ],
      "reviewPolicy": {
        "minApprovals": 0
      }
    }
  },
  "docsDriftRules": {
    "requireDocsUpdate": [
      "crates/openfang-api/src/routes.rs",
      "crates/openfang-types/src/config.rs"
    ],
    "docsFiles": [
      "docs/configuration.md",
      "docs/cli-reference.md",
      "docs/architecture.md",
      "README.md"
    ],
    "maxStaleDays": 30
  },
  "reviewPolicySemantics": {
    "staleThresholdMinutes": 60,
    "timeoutThresholdMinutes": 120,
    "validStates": [
      "success",
      "queued",
      "in_progress"
    ],
    "invalidStates": [
      "failed",
      "timeout",
      "cancelled",
      "skipped"
    ]
  },
  "reviewPolicy": {
    "provider": "greptile",
    "checkRunName": "greptile-review",
    "timeoutMinutes": 20,
    "weakConfidenceThreshold": 0.55,
    "actionableSummaryKeywords": [
      "fix",
      "failure",
      "error",
      "panic",
      "unsafe",
      "leak",
      "regression"
    ]
  },
  "reviewProviders": {
    "mode": "alongside",
    "primary": "greptile",
    "providers": {
      "greptile": {
        "enabled": true,
        "enforcement": "required",
        "checkRunName": "greptile-review",
        "timeoutMinutes": 20,
        "weakConfidenceThreshold": 0.55,
        "actionableSummaryKeywords": [
          "fix",
          "failure",
          "error",
          "panic",
          "unsafe",
          "leak",
          "regression"
        ]
      },
      "claude": {
        "enabled": true,
        "enforcement": "required",
        "source": "github_pr_comments",
        "requireCurrentHeadIngestion": true,
        "github": {
          "trustedActorLogins": [
            "gagan114662"
          ],
          "trustedAppIds": [],
          "trustedAppIdsEnv": "OPENFANG_CLAUDE_TRUSTED_APP_IDS",
          "commentMarker": "<!-- openfang-claude-feedback -->",
          "requireHeadShaMatch": true
        },
        "parse": {
          "format": "json_block",
          "maxFindings": 200
        }
      }
    }
  },
  "automation": {
    "claudeRemediation": {
      "enabled": true,
      "triggerLabel": "claude-remediate",
      "runOnEverySync": true,
      "requireFindingsIngestion": true,
      "maxAttemptsPerSha": 1,
      "applyCommandVar": "OPENFANG_CLAUDE_REMEDIATION_CMD",
      "validationCommandVar": "OPENFANG_CLAUDE_VALIDATION_CMD"
    },
    "evalRemediation": {
      "enabled": true,
      "triggerLabel": "eval-remediate",
      "maxAttemptsPerSha": 1,
      "applyCommandVar": "OPENFANG_EVAL_REMEDIATION_CMD",
      "validationCommandVar": "OPENFANG_EVAL_VALIDATION_CMD"
    }
  },
  "evidencePolicy": {
    "uiImpactPaths": [
      "crates/openfang-api/static/**",
      "crates/openfang-desktop/**",
      "public/**"
    ],
    "requiredFlows": [
      "diff-summary-capture",
      "verification-summary-capture",
      "checklist-preview-capture",
      "implementation-walkthrough-video"
    ],
    "requiredAssertions": []
  },
  "prReviewHarness": {
    "enabled": true,
    "requiredCheckName": "pr-review-harness",
    "minScreenshots": 2,
    "minVideos": 1,
    "maxFiles": 200,
    "requiredEvidenceAssertions": []
  },
  "rerunCommentDedupeMarker": "<!-- greptile-rerun-request -->",
  "remediationGuardrails": {
    "allowedPaths": [
      "crates/**/src/**/*.rs",
      "tests/**/*.rs",
      "docs/**/*.md"
    ],
    "blockedPaths": [
      ".git/**",
      ".github/**",
      "target/**",
      "Cargo.lock"
    ],
    "maxFilesPerPR": 10,
    "maxLinesPerFile": 500
  },
  "browserEvidenceRequirements": {
    "uiChangePaths": [
      "crates/openfang-api/static/**",
      "crates/openfang-desktop/**"
    ],
    "requiredScreenshots": 2,
    "requireBeforeAfter": true
  },
  "agentEvalPolicy": {
    "enabled": true,
    "blockingCheckName": "agent-evals-pr",
    "blockingProfile": {
      "llm_mode": "mock_frozen",
      "network_mode": "isolated",
      "seed": 42
    },
    "nightlyProfile": {
      "llm_mode": "mixed_advisory",
      "network_mode": "restricted",
      "seed": 42
    },
    "blockingThreshold": 1.0,
    "maxScenarioRuntimeSecs": 90,
    "remediationLabel": "eval-remediate",
    "maxRemediationFindingsPerRun": 25,
    "liveProviderGate": {
      "enabled": true,
      "blockingRiskTiers": [
        "critical",
        "high"
      ],
      "checkName": "agent-evals-live-pr",
      "minSuccessfulProviders": 1,
      "retries": {
        "attempts": 3,
        "backoffSeconds": [
          5,
          20,
          60
        ]
      },
      "providerCatalog": {
        "openai": {
          "env": "OPENAI_API_KEY",
          "url": "https://api.openai.com/v1/models",
          "method": "GET"
        },
        "anthropic": {
          "env": "ANTHROPIC_API_KEY",
          "url": "https://api.anthropic.com/v1/models",
          "method": "GET"
        },
        "gemini": {
          "env": "GEMINI_API_KEY",
          "url": "https://generativelanguage.googleapis.com/v1beta/models",
          "method": "GET"
        }
      },
      "failIfNoProviderSecrets": true
    },
    "novelFailureBackfill": {
      "enabled": true,
      "maxNewScenariosPerRun": 25,
      "minConfidence": 0.7,
      "targetScenarioFile": ".harness/evals/scenarios.generated.json",
      "dedupeFile": ".harness/evals/novel-failure-signatures.json",
      "autoPr": true
    },
    "infraPreflight": {
      "enabled": true,
      "checkName": "infra-preflight",
      "requiredForWorkflows": [
        "risk-policy-gate",
        "agent-evals-pr",
        "agent-evals-live-pr",
        "pr-review-harness",
        "sentry-remediation-agent",
        "claude-remediation-agent",
        "agent-eval-remediation"
      ],
      "retryPolicy": {
        "attempts": 3,
        "backoffSeconds": [
          5,
          20,
          60
        ]
      },
      "incident": {
        "enabled": true,
        "label": "infra-incident",
        "marker": "<!-- openfang-infra-incident -->"
      }
    }
  },
  "sentryWorkflowTelemetry": {
    "enabled": true,
    "emitOnFailureOnly": true,
    "dsnEnv": "SENTRY_DSN",
    "artifactPath": "artifacts/sentry-workflow-emit.json"
  }
}
