{
  "mcpServers": {
    "openfang": {
      "command": "cargo",
      "args": ["run", "--quiet", "-p", "openfang-cli", "--", "mcp"],
      "env": {
        "RUST_LOG": "openfang=info"
      }
    },
    "contextplus": {
      "command": "npx",
      "args": ["-y", "contextplus"],
      "env": {
        "OLLAMA_EMBED_MODEL": "nomic-embed-text",
        "OLLAMA_CHAT_MODEL": "llama3.2"
      }
    }
  }
}
