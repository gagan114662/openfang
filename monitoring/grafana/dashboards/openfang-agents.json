{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "loki", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "pluginVersion": "11.6.0",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "" },
          "expr": "count(count_over_time({job=\"openfang\", agent=~\"$agent\"} | json | agent != \"\" [$__range]) by (agent))",
          "refId": "A"
        }
      ],
      "title": "Active Agents",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "",
            "fillOpacity": 20,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "stacking": { "group": "A", "mode": "none" }
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 10, "x": 8, "y": 0 },
      "id": 2,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "11.6.0",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "" },
          "expr": "sum by (agent) (count_over_time({job=\"openfang\", agent=~\"$agent\"} [$__interval]))",
          "legendFormat": "{{agent}}",
          "refId": "A"
        }
      ],
      "title": "Agent Log Volume",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "pluginVersion": "11.6.0",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "" },
          "expr": "count_over_time({job=\"openfang\", agent=~\"$agent\"} | json | level = \"ERROR\" [$__range])",
          "refId": "A"
        }
      ],
      "title": "Errors",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "" },
      "gridPos": { "h": 12, "w": 16, "x": 0, "y": 6 },
      "id": 4,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "pluginVersion": "11.6.0",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "" },
          "expr": "{job=\"openfang\", agent=~\"$agent\"} | json",
          "refId": "A"
        }
      ],
      "title": "Recent Logs",
      "type": "logs"
    },
    {
      "datasource": { "type": "loki", "uid": "" },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": { "h": 12, "w": 8, "x": 16, "y": 6 },
      "id": 5,
      "options": {
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Time" }]
      },
      "pluginVersion": "11.6.0",
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "" },
          "expr": "{job=\"openfang\", agent=~\"$agent\"} | json | level =~ \"ERROR|WARN\"",
          "refId": "A"
        }
      ],
      "title": "Warnings & Errors",
      "type": "table",
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "source": "labels"
          }
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["openfang", "agents", "loki"],
  "templating": {
    "list": [
      {
        "current": {
          "selected": true,
          "text": ["All"],
          "value": ["$__all"]
        },
        "datasource": { "type": "loki", "uid": "" },
        "definition": "label_values({job=\"openfang\"}, agent)",
        "includeAll": true,
        "multi": true,
        "name": "agent",
        "query": "label_values({job=\"openfang\"}, agent)",
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "OpenFang Agent Monitor",
  "uid": "openfang-agents",
  "version": 1
}
